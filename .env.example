# りもこズッ友キラキラポボモフォ2.0
# Copy this file to .env and edit local values.

# Default backend. Use codex while MI25 is not ready.
ZUTTOMO_DEFAULT_BACKEND=codex

# Keep MI25 sealed until the local server is ready.
ZUTTOMO_MI25_ENABLED=false
ZUTTOMO_MI25_BASE_URL=http://127.0.0.1:8000/v1
ZUTTOMO_MI25_MODEL=local-model

# OpenRouter. Leave OPENROUTER_API_KEY empty until needed.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Codex CLI backend.
CODEX_BIN=codex
# CODEX_WORKDIR=/path/to/project

# Local files and UI behavior.
ZUTTOMO_HISTORY=zuttomo-history.jsonl
ZUTTOMO_NO_AA=1

# Pair mode: small phone input form.
ZUTTOMO_PAIR_HOST=0.0.0.0
ZUTTOMO_PAIR_PORT=8787
ZUTTOMO_OSS_URL=https://limonene213u.github.io/ai-2026-computex/

# HTTP timeout for MI25/OpenRouter.
ZUTTOMO_HTTP_TIMEOUT_SECS=120
